# MySQL (openmetadata_mysql container — dev container defaults)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=openmetadata_user
MYSQL_PASSWORD=openmetadata_password
MYSQL_DATABASE=supply_chain_analytics

# MySQL host as seen FROM the OpenMetadata server container (for ingestion)
# Inside Docker network, containers reach each other by service name.
MYSQL_HOST_FOR_INGESTION=mysql

# OpenAI (for Narrator agent — LLM-powered report generation)
OPENAI_API_KEY=sk-...

# DataPulse Settings
DATAPULSE_POLL_INTERVAL_SECONDS=30
DATAPULSE_SEVERITY_THRESHOLD=2
